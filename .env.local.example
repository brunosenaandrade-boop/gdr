# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Meta WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_APP_SECRET=your-app-secret

# WhatsApp Flows (formulário de cadastro nativo)
WHATSAPP_FLOW_ID=your-flow-id
WHATSAPP_FLOW_TOKEN=your-flow-token
WHATSAPP_TUTORIAL_FLOW_ID=your-tutorial-flow-id

# Mercado Pago (pagamentos)
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MP_PUBLIC_KEY=your-mercadopago-public-key

# eNotas (emissão de NF-e) — opcional
ENOTAS_API_KEY=your-enotas-api-key
ENOTAS_EMPRESA_ID=your-enotas-empresa-id

# Subdomínios (admin e afiliado)
ADMIN_DOMAIN=admin.guardadinheiro.com.br
AFFILIATE_DOMAIN=afiliado.guardadinheiro.com.br

# Resend (email transacional)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Guarda Dinheiro <noreply@guardadinheiro.com.br>

# URLs do site
NEXT_PUBLIC_SITE_URL=https://www.guardadinheiro.com.br
NEXT_PUBLIC_APP_URL=https://www.guardadinheiro.com.br

# PostHog (analytics) — opcional
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key

# Sentry (observabilidade)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Vercel Cron (gerado automaticamente pela Vercel)
CRON_SECRET=your-cron-secret
