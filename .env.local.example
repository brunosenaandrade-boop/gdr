# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Meta WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_APP_SECRET=your-app-secret

# WhatsApp Flows (formulário de cadastro nativo)
WHATSAPP_FLOW_ID=your-flow-id
WHATSAPP_FLOW_TOKEN=your-flow-token

# Hotmart (assinatura + webhook)
HOTMART_HOTTOK=your-hotmart-hottok
HOTMART_PRODUCT_ID=your-hotmart-product-id
HOTMART_CHECKOUT_URL=https://pay.hotmart.com/YOUR_PRODUCT_CODE

# eNotas (emissão de NF-e)
ENOTAS_API_KEY=your-enotas-api-key
ENOTAS_EMPRESA_ID=your-enotas-empresa-id

# Sentry (observabilidade)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
